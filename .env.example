# =====================================================================
# MT Safaris — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================================

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=production
# No trailing slash. Use https:// in production.
APP_URL=https://www.yourdomain.com

# ── Database ─────────────────────────────────────────────────────────
# On cPanel the DB host is usually localhost.
# DB_NAME format on cPanel is typically: cpanelusername_dbname
# DB_USER format on cPanel is typically: cpanelusername_dbuser
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpanelusername_mtsafaris
DB_USER=cpanelusername_dbuser
DB_PASS=your_database_password

# ── Email (cPanel Mail or SMTP) ───────────────────────────────────────
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=MT Safaris
# Leave SMTP fields empty to use PHP mail() — fine for cPanel built-in mail.
# Fill in SMTP settings if using an external provider (Gmail, Mailgun, etc.)
MAIL_SMTP_HOST=mail.yourdomain.com
MAIL_SMTP_PORT=465
MAIL_SMTP_USER=noreply@yourdomain.com
MAIL_SMTP_PASS=your_email_password

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Set to false in production
PAYPAL_SANDBOX=false
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ── Google / reCAPTCHA ───────────────────────────────────────────────
GOOGLE_MAPS_KEY=
GOOGLE_ANALYTICS=G-XXXXXXXXXX
RECAPTCHA_SITE=
RECAPTCHA_SECRET=
